---
import '../../src/style.css'
import { buildGalleryAsciidoc } from '../lib/gallery-asciidoc.js'

const { lang, homeHref, homeLabel, alternateHref, alternateLabel, title, lead, intro, rawHref, rawLabel, samples } = Astro.props
const asciidoc = buildGalleryAsciidoc(samples, { title, intro })
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={lead} />
    <title>{title} | asciidoctor-kroki-embedded</title>
  </head>
  <body>
    <main class="gallery-main">
      <nav class="language-nav gallery-top-nav" aria-label="Navigation">
        <a href={homeHref}>{homeLabel}</a>
        <a href={alternateHref}>{alternateLabel}</a>
      </nav>

      <header class="gallery-hero page-panel">
        <p class="eyebrow">AsciiDoc diagram gallery</p>
        <h1>{title}</h1>
        <p class="lead">{lead}</p>
        <p>{intro}</p>
        <p><a class="download-link" href={rawHref}>{rawLabel}</a></p>
      </header>

      <section class="gallery-document" aria-label={title}>
        <pre><code>{asciidoc}</code></pre>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --ink: #14211f;
    --muted: #5a6865;
    --paper: #f7f5ef;
    --surface: #ffffff;
    --line: #cfd8d4;
    --accent: #0f766e;
    --accent-strong: #115e59;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    min-width: 320px;
    color: var(--ink);
    background: linear-gradient(180deg, rgba(15, 118, 110, 0.08), transparent 34rem), var(--paper);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    line-height: 1.55;
  }

  .gallery-main {
    width: min(1080px, calc(100% - 32px));
    margin: 0 auto;
    padding: 28px 0 56px;
  }

  .language-nav { display: flex; justify-content: flex-end; gap: 8px; }

  .language-nav a,
  .download-link {
    display: inline-flex;
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 7px 10px;
    color: var(--accent-strong);
    background: rgba(255, 255, 255, 0.86);
    font-size: 0.88rem;
    font-weight: 800;
    text-decoration: none;
  }

  .language-nav a:hover,
  .language-nav a:focus-visible,
  .download-link:hover,
  .download-link:focus-visible { border-color: var(--accent); background: rgba(15, 118, 110, 0.08); }

  .gallery-hero {
    margin: 28px 0 24px;
    padding: clamp(28px, 5vw, 64px);
    border: 1px solid var(--line);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.88);
    box-shadow: 0 18px 48px rgba(20, 33, 31, 0.08);
  }

  .eyebrow {
    margin: 0 0 10px;
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1 { margin: 0; max-width: 12ch; font-size: clamp(2.4rem, 6vw, 5rem); line-height: 0.98; }
  p { overflow-wrap: anywhere; }

  .lead { margin: 20px 0 0; max-width: 820px; color: var(--muted); font-size: clamp(1.05rem, 2vw, 1.24rem); }
  .gallery-hero p:not(.eyebrow) { max-width: 820px; color: var(--muted); }

  .gallery-document {
    border: 1px solid var(--line);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 18px 48px rgba(20, 33, 31, 0.08);
    overflow: hidden;
  }

  pre {
    margin: 0;
    overflow: auto;
    padding: 18px;
    background: white;
  }

  code, pre { font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace; font-size: 0.9rem; line-height: 1.55; }

  @media (max-width: 560px) { .gallery-main { width: min(100% - 20px, 1080px); padding-top: 10px; } h1 { max-width: none; } }
</style>
