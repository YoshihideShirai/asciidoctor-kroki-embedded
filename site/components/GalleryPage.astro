---
import '../../src/style.css'

const { lang, homeHref, homeLabel, alternateHref, alternateLabel, title, lead, intro, copyLabel, copiedLabel, samples } = Astro.props
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={lead} />
    <title>{title} | asciidoctor-kroki-embedded</title>
  </head>
  <body>
    <main class="gallery-main">
      <nav class="language-nav gallery-top-nav" aria-label="Navigation">
        <a href={homeHref}>{homeLabel}</a>
        <a href={alternateHref}>{alternateLabel}</a>
      </nav>

      <header class="gallery-hero page-panel">
        <p class="eyebrow">AsciiDoc diagram gallery</p>
        <h1>{title}</h1>
        <p class="lead">{lead}</p>
        <p>{intro}</p>
      </header>

      <section class="gallery-grid" aria-label={title}>
        {samples.map((sample) => (
          <article class="gallery-card" data-diagram-type={sample.type}>
            <div class="gallery-card-header">
              <div>
                <p class="eyebrow">{sample.type}</p>
                <h2>{sample.title}</h2>
              </div>
              <button class="copy-button" type="button" data-copy-label={copyLabel} data-copied-label={copiedLabel}>{copyLabel}</button>
            </div>
            <p>{sample.description}</p>
            <div class="gallery-preview" aria-live="polite"></div>
            <details>
              <summary>AsciiDoc</summary>
              <pre><code class="gallery-asciidoc-source">{`[${sample.type}]
----
${sample.source}
----`}</code></pre>
            </details>
          </article>
        ))}
      </section>
    </main>

    <script src={`${import.meta.env.BASE_URL}vendor/plantuml-core/viz-global.js`}></script>
    <script>
      import asciidoctorFactory from '@asciidoctor/core'
      import { renderToString } from '@plantuml/core'
      import bitfield from 'bit-field'
      import JSON5 from 'json5'
      import mermaid from 'mermaid'
      import nomnoml from 'nomnoml'
      import loadPikchr from 'pikchr-js'
      import { instance as createGraphviz } from '@viz-js/viz'
      import * as vega from 'vega'
      import * as vegaInterpreter from 'vega-interpreter'
      import * as vegaLite from 'vega-lite'
      import WaveDrom from 'wavedrom'
      import waveSkin from 'wavedrom/skins/default.js'
      import { hydrateEmbeddedDiagrams, installNetworkGuards } from '../../src/browser.js'
      import { registerBrowserDiagrams } from '../lib/browser-kroki.js'

      const asciidoctor = asciidoctorFactory()
      const graphviz = createGraphviz()
      const pikchr = loadPikchr()
      const diagramNames = [...document.querySelectorAll('.gallery-card')].map((card) => card.dataset.diagramType)

      globalThis.WaveSkin = waveSkin
      installNetworkGuards(globalThis)
      mermaid.initialize({ startOnLoad: false, securityLevel: 'strict', theme: 'default' })

      function renderPlantUml(sourceText) {
        return new Promise((resolve, reject) => {
          renderToString(
            sourceText.split(/\r\n|\r|\n/),
            (svg) => resolve(svg),
            (message) => reject(new Error(String(message || 'PlantUML rendering failed'))),
          )
        })
      }

      function escapeSvgText(value) {
        return String(value).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')
      }

      function renderTextDiagramSvg(sourceText) {
        const lines = sourceText.split(/\r\n|\r|\n/)
        const width = Math.max(180, Math.max(...lines.map((line) => line.length), 1) * 8 + 24)
        const height = Math.max(48, lines.length * 18 + 24)
        const text = lines.map((line, index) => `<text x="12" y="${24 + index * 18}">${escapeSvgText(line)}</text>`).join('')
        return `<svg xmlns="http://www.w3.org/2000/svg" role="img" viewBox="0 0 ${width} ${height}" width="${width}" height="${height}"><rect width="100%" height="100%" rx="6" fill="#f8fafc" stroke="#94a3b8"/><g font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-size="14" fill="#14211f">${text}</g></svg>`
      }

      async function renderGraphviz(sourceText) {
        const viz = await graphviz
        return viz.renderString(sourceText, { format: 'svg' })
      }

      function createRegistry() {
        const registry = asciidoctor.Extensions.create()
        registerBrowserDiagrams(registry, { defaultFormat: 'svg', diagramNames })
        return registry
      }

      async function hydratePreview(container) {
        return hydrateEmbeddedDiagrams(container, {
          libraries: { mermaid, nomnoml, vega, vegaLite, vegaInterpreter, WaveDrom, JSON5, bitfield, svgbob: renderTextDiagramSvg, pikchr: await pikchr, graphviz: renderGraphviz },
          renderers: { plantuml: async ({ source: sourceText, output }) => { output.innerHTML = await renderPlantUml(sourceText) } },
        })
      }

      async function renderCard(card) {
        const type = card.dataset.diagramType
        const source = card.querySelector('.gallery-asciidoc-source').textContent
        const preview = card.querySelector('.gallery-preview')
        preview.innerHTML = String(asciidoctor.convert(source, {
          safe: 'safe', backend: 'html5', standalone: false, extension_registry: createRegistry(), attributes: { 'allow-uri-read': false },
        }))
        await hydratePreview(preview)
      }

      document.querySelectorAll('.gallery-card').forEach((card) => {
        const button = card.querySelector('.copy-button')
        button.addEventListener('click', async () => {
          await navigator.clipboard.writeText(card.querySelector('code').textContent)
          button.textContent = button.dataset.copiedLabel
          setTimeout(() => { button.textContent = button.dataset.copyLabel }, 1400)
        })
      })

      for (const card of document.querySelectorAll('.gallery-card')) {
        try {
          await renderCard(card)
        } catch (error) {
          card.querySelector('.gallery-preview').innerHTML = `<pre class="site-error"></pre>`
          card.querySelector('.site-error').textContent = error instanceof Error ? error.message : String(error)
        }
      }
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --ink: #14211f;
    --muted: #5a6865;
    --paper: #f7f5ef;
    --surface: #ffffff;
    --line: #cfd8d4;
    --accent: #0f766e;
    --accent-strong: #115e59;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    min-width: 320px;
    color: var(--ink);
    background: linear-gradient(180deg, rgba(15, 118, 110, 0.08), transparent 34rem), var(--paper);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    line-height: 1.55;
  }

  .gallery-main {
    width: min(1280px, calc(100% - 32px));
    margin: 0 auto;
    padding: 28px 0 56px;
  }

  .language-nav { display: flex; justify-content: flex-end; gap: 8px; }

  .language-nav a,
  .copy-button {
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 7px 10px;
    color: var(--accent-strong);
    background: rgba(255, 255, 255, 0.86);
    font-size: 0.88rem;
    font-weight: 800;
    text-decoration: none;
  }

  .gallery-hero {
    margin: 28px 0 24px;
    padding: clamp(28px, 5vw, 64px);
    border: 1px solid var(--line);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.88);
    box-shadow: 0 18px 48px rgba(20, 33, 31, 0.08);
  }

  .eyebrow {
    margin: 0 0 10px;
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1 { margin: 0; max-width: 12ch; font-size: clamp(2.4rem, 6vw, 5rem); line-height: 0.98; }
  h2 { margin: 0; font-size: 1.05rem; }
  p { overflow-wrap: anywhere; }

  .lead { margin: 20px 0 0; max-width: 820px; color: var(--muted); font-size: clamp(1.05rem, 2vw, 1.24rem); }
  .gallery-hero p:last-child { max-width: 820px; color: var(--muted); }

  .gallery-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18px; }

  .gallery-card {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 18px;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 18px 48px rgba(20, 33, 31, 0.08);
  }

  .gallery-card-header { display: flex; align-items: start; justify-content: space-between; gap: 12px; }
  .gallery-card > p { margin: 0; color: var(--muted); }

  .copy-button { width: auto; cursor: pointer; }
  .copy-button:hover, .copy-button:focus-visible, .language-nav a:hover, .language-nav a:focus-visible { border-color: var(--accent); background: rgba(15, 118, 110, 0.08); }

  .gallery-preview {
    min-height: 260px;
    overflow: auto;
    display: grid;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 16px;
    background: #fbfaf6;
  }

  .gallery-preview .kroki-embedded { margin: 0; }
  .gallery-preview .kroki-embedded-output svg { margin: auto; }

  details { border: 1px solid var(--line); border-radius: 8px; background: #fbfaf6; }
  summary { cursor: pointer; padding: 10px 12px; color: var(--accent-strong); font-weight: 800; }
  pre { margin: 0; max-height: 300px; overflow: auto; border-top: 1px solid var(--line); padding: 12px; background: white; }
  code, pre { font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace; font-size: 0.86rem; line-height: 1.45; }
  .site-error { white-space: pre-wrap; color: #b00020; }

  @media (max-width: 860px) { .gallery-grid { grid-template-columns: 1fr; } h1 { max-width: none; } }
  @media (max-width: 560px) { .gallery-main { width: min(100% - 20px, 1280px); padding-top: 10px; } .gallery-card-header { flex-direction: column; } .copy-button { width: 100%; } }
</style>
