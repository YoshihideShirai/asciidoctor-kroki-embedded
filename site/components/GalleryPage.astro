---
import '../../src/style.css'
import { buildGalleryAsciidoc } from '../lib/gallery-asciidoc.js'

const { lang, homeHref, homeLabel, alternateHref, alternateLabel, title, lead, intro, rawHref, rawLabel, samples } = Astro.props
const asciidoc = buildGalleryAsciidoc(samples, { title, intro })
const serializedAsciidoc = JSON.stringify(asciidoc)
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={lead} />
    <title>{title} | asciidoctor-kroki-embedded</title>
  </head>
  <body>
    <main class="gallery-main">
      <nav class="language-nav gallery-top-nav" aria-label="Navigation">
        <a href={homeHref}>{homeLabel}</a>
        <a href={alternateHref}>{alternateLabel}</a>
      </nav>

      <header class="gallery-hero page-panel">
        <p class="eyebrow">AsciiDoc diagram gallery</p>
        <h1>{title}</h1>
        <p class="lead">{lead}</p>
        <p>{intro}</p>
        <p><a class="download-link" href={rawHref}>{rawLabel}</a></p>
      </header>

      <section class="gallery-rendered page-panel" aria-labelledby="gallery-rendered-title">
        <div class="gallery-section-header">
          <div>
            <p class="eyebrow">Rendered with Asciidoctor.js</p>
            <h2 id="gallery-rendered-title">{title}</h2>
          </div>
          <output id="gallery-render-status" aria-live="polite">ready</output>
        </div>
        <article id="gallery-rendered-output" class="gallery-rendered-output"></article>
      </section>

      <details class="gallery-document">
        <summary>AsciiDoc source</summary>
        <pre><code>{asciidoc}</code></pre>
      </details>

      <script type="application/json" id="gallery-asciidoc" set:html={serializedAsciidoc}></script>
    </main>

    <script>
      import asciidoctorFactory from '@asciidoctor/core'
      import bitfield from 'bit-field'
      import JSON5 from 'json5'
      import mermaid from 'mermaid'
      import nomnoml from 'nomnoml'
      import { renderToString } from '@plantuml/core'
      import loadPikchr from 'pikchr-js'
      import { instance as createGraphviz } from '@viz-js/viz'
      import * as vega from 'vega'
      import * as vegaInterpreter from 'vega-interpreter'
      import * as vegaLite from 'vega-lite'
      import WaveDrom from 'wavedrom'
      import waveSkin from 'wavedrom/skins/default.js'
      import { hydrateEmbeddedDiagrams, installNetworkGuards } from '../../src/browser.js'
      import { registerBrowserDiagrams } from '../lib/browser-kroki.js'

      const asciidoc = JSON.parse(document.querySelector('#gallery-asciidoc').textContent)
      const output = document.querySelector('#gallery-rendered-output')
      const status = document.querySelector('#gallery-render-status')
      const asciidoctor = asciidoctorFactory()
      const graphviz = createGraphviz()
      const pikchr = loadPikchr()

      globalThis.WaveSkin = waveSkin
      installNetworkGuards(globalThis)
      mermaid.initialize({
        startOnLoad: false,
        securityLevel: 'strict',
        theme: 'default',
      })

      function canRenderWithPlantUmlCore(sourceText) {
        return /^@startuml\b/i.test(sourceText.trim()) &&
          /(?:^|\n)\s*(?:participant|boundary|control|entity|database|collections|queue)\b/i.test(sourceText) &&
          /(?:--?>|<-?-).*:/m.test(sourceText)
      }

      function renderPlantUml(sourceText) {
        if (!canRenderWithPlantUmlCore(sourceText)) {
          return Promise.resolve(renderTextDiagramSvg(sourceText))
        }

        const renderTimeoutMs = 3000
        let timeoutId

        const render = new Promise((resolve, reject) => {
          try {
            renderToString(
              sourceText.split(/\r\n|\r|\n/),
              (svg) => {
                clearTimeout(timeoutId)
                resolve(svg)
              },
              (message) => reject(new Error(String(message || 'PlantUML rendering failed'))),
            )
          } catch (error) {
            reject(error)
          }
        })

        const timeout = new Promise((_, reject) => {
          timeoutId = setTimeout(() => {
            reject(new Error('PlantUML rendering timed out in the browser renderer.'))
          }, renderTimeoutMs)
        })

        return Promise.race([render, timeout])
      }

      function escapeSvgText(value) {
        return String(value)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
      }

      function renderTextDiagramSvg(sourceText) {
        const lines = sourceText.split(/\r\n|\r|\n/)
        const width = Math.max(180, Math.max(...lines.map((line) => line.length), 1) * 8 + 24)
        const height = Math.max(48, lines.length * 18 + 24)
        const text = lines
          .map((line, index) => `<text x="12" y="${24 + index * 18}">${escapeSvgText(line)}</text>`)
          .join('')
        return `<svg xmlns="http://www.w3.org/2000/svg" role="img" viewBox="0 0 ${width} ${height}" width="${width}" height="${height}"><rect width="100%" height="100%" rx="6" fill="#f8fafc" stroke="#94a3b8"/><g font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-size="14" fill="#14211f">${text}</g></svg>`
      }

      async function renderGraphviz(sourceText) {
        const viz = await graphviz
        return viz.renderString(sourceText, { format: 'svg' })
      }

      function createRegistry() {
        const registry = asciidoctor.Extensions.create()
        registerBrowserDiagrams(registry, { defaultFormat: 'svg' })
        return registry
      }

      async function renderGallery() {
        status.value = 'rendering'
        output.textContent = ''

        try {
          output.innerHTML = String(asciidoctor.convert(asciidoc, {
            safe: 'safe',
            backend: 'html5',
            standalone: false,
            extension_registry: createRegistry(),
            attributes: {
              'allow-uri-read': false,
            },
          }))

          const results = await hydrateEmbeddedDiagrams(output, {
            libraries: {
              mermaid,
              nomnoml,
              vega,
              vegaLite,
              vegaInterpreter,
              WaveDrom,
              JSON5,
              bitfield,
              svgbob: renderTextDiagramSvg,
              pikchr: await pikchr,
              graphviz: renderGraphviz,
              plantuml: renderPlantUml,
            },
          })
          const failed = results.find((result) => !result.ok)
          status.value = failed || results.length === 0 ? 'failed' : 'rendered'
        } catch (error) {
          output.innerHTML = '<pre class="site-error"></pre>'
          output.querySelector('.site-error').textContent =
            error instanceof Error ? error.message : String(error)
          status.value = 'failed'
        }
      }

      renderGallery()
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --ink: #14211f;
    --muted: #5a6865;
    --paper: #f7f5ef;
    --surface: #ffffff;
    --line: #cfd8d4;
    --accent: #0f766e;
    --accent-strong: #115e59;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    min-width: 320px;
    color: var(--ink);
    background: linear-gradient(180deg, rgba(15, 118, 110, 0.08), transparent 34rem), var(--paper);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    line-height: 1.55;
  }

  .gallery-main {
    width: min(1080px, calc(100% - 32px));
    margin: 0 auto;
    padding: 28px 0 56px;
  }

  .language-nav { display: flex; justify-content: flex-end; gap: 8px; }

  .language-nav a,
  .download-link {
    display: inline-flex;
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 7px 10px;
    color: var(--accent-strong);
    background: rgba(255, 255, 255, 0.86);
    font-size: 0.88rem;
    font-weight: 800;
    text-decoration: none;
  }

  .language-nav a:hover,
  .language-nav a:focus-visible,
  .download-link:hover,
  .download-link:focus-visible { border-color: var(--accent); background: rgba(15, 118, 110, 0.08); }

  .gallery-hero {
    margin: 28px 0 24px;
    padding: clamp(28px, 5vw, 64px);
    border: 1px solid var(--line);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.88);
    box-shadow: 0 18px 48px rgba(20, 33, 31, 0.08);
  }

  .eyebrow {
    margin: 0 0 10px;
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1 { margin: 0; max-width: 12ch; font-size: clamp(2.4rem, 6vw, 5rem); line-height: 0.98; }
  p { overflow-wrap: anywhere; }

  .lead { margin: 20px 0 0; max-width: 820px; color: var(--muted); font-size: clamp(1.05rem, 2vw, 1.24rem); }
  .gallery-hero p:not(.eyebrow) { max-width: 820px; color: var(--muted); }

  .gallery-rendered,
  .gallery-document {
    border: 1px solid var(--line);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 18px 48px rgba(20, 33, 31, 0.08);
    overflow: hidden;
  }

  .gallery-rendered { margin-bottom: 20px; }

  .gallery-section-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    padding: 18px;
    border-bottom: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.72);
  }

  .gallery-section-header h2 { margin: 0; font-size: clamp(1.5rem, 3vw, 2.2rem); }
  .gallery-section-header output { color: var(--muted); font-family: monospace; font-weight: 700; }

  .gallery-rendered-output { padding: 18px; background: white; }
  .gallery-rendered-output :global(.sect1 + .sect1) { margin-top: 28px; padding-top: 20px; border-top: 1px solid var(--line); }
  .gallery-rendered-output :global(.kroki-embedded-output) { overflow: auto; }
  .gallery-rendered-output :global(svg) { max-width: 100%; height: auto; }

  .gallery-document summary {
    cursor: pointer;
    padding: 14px 18px;
    color: var(--accent-strong);
    font-weight: 800;
  }

  pre {
    margin: 0;
    overflow: auto;
    padding: 18px;
    background: white;
  }

  code, pre { font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace; font-size: 0.9rem; line-height: 1.55; }

  @media (max-width: 560px) { .gallery-main { width: min(100% - 20px, 1080px); padding-top: 10px; } h1 { max-width: none; } }
</style>
