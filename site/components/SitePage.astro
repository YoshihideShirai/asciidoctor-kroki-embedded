---
import '../../src/style.css'

const {
  lang,
  description,
  alternateHref,
  alternateLabel,
  lead,
  primaryAction,
  galleryHref,
  galleryAction,
  antoraHref,
  antoraAction,
  sections,
  heroVisualPolicy,
  valueAria,
  valueProps,
  playgroundTitle,
  playgroundBody,
  asciidoctorPreviewTitle,
  asciidoctorPreviewBody,
  asciidoctorSourceLabel,
  asciidoctorPreviewLabel,
  details,
} = Astro.props
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content={description}
    />
    <title>asciidoctor-kroki-embedded</title>
  </head>
  <body>
    <main>
      <nav class="language-nav" aria-label="Language">
        <a href={alternateHref}>{alternateLabel}</a>
      </nav>

      <nav class="page-nav" aria-label="Page sections">
        <a href="#overview">{sections.overview}</a>
        <a href="#playground">{sections.renderer}</a>
        <a href="#asciidoctor-preview">{sections.asciidoctor}</a>
        <a href={antoraHref}>{sections.antora}</a>
      </nav>

      <section id="overview" class="hero page-panel" aria-labelledby="title">
        <div class="hero-copy">
          <p class="eyebrow">Kroki-compatible local rendering</p>
          <h1 id="title">asciidoctor-kroki-embedded</h1>
          <p class="lead">{lead}</p>
          <div class="hero-actions" aria-label="Primary actions">
            <a href="#playground">{primaryAction}</a>
            <a class="secondary-action" href={galleryHref}>{galleryAction}</a>
            <a class="secondary-action" href={antoraHref}>{antoraAction}</a>
            <code>npm install asciidoctor-kroki-embedded</code>
          </div>
        </div>

        <div class="hero-visual" aria-label="Rendering flow">
          <div>
            <span>AsciiDoc</span>
            <pre>[plantuml]
----
Alice -> Bob: hello
----</pre>
          </div>
          <div>
            <span>Embedded target</span>
            <pre>&lt;figure data-diagram-type="plantuml"&gt;
  &lt;pre&gt;Alice -> Bob...&lt;/pre&gt;
  &lt;div class="kroki-embedded-output"&gt;&lt;/div&gt;
&lt;/figure&gt;</pre>
          </div>
          <div>
            <span>Local hydration</span>
            <p>{heroVisualPolicy}</p>
          </div>
        </div>
      </section>

      <section class="value-props" aria-label={valueAria}>
        {valueProps.map((item) => (
          <article>
            <h2>{item.title}</h2>
            <p set:html={item.body} />
          </article>
        ))}
      </section>

      <section id="playground" class="playground-section page-panel" aria-labelledby="playground-title">
        <div class="section-heading">
          <p class="eyebrow">Try the embedded renderers</p>
          <h2 id="playground-title">{playgroundTitle}</h2>
          <p>{playgroundBody}</p>
        </div>

        <div class="playground" aria-label="Renderer playground">
          <form class="controls">
            <label>
              <span>Renderer</span>
              <select id="diagram-type" name="diagram-type">
                <option value="plantuml">PlantUML</option>
                <option value="mermaid">Mermaid</option>
                <option value="nomnoml">Nomnoml</option>
                <option value="vegalite">Vega-Lite</option>
                <option value="vega">Vega</option>
                <option value="wavedrom">WaveDrom</option>
                <option value="bytefield">Bytefield</option>
                <option value="svgbob">SvgBob</option>
                <option value="pikchr">Pikchr</option>
                <option value="graphviz">GraphViz</option>
              </select>
            </label>
            <button id="render-button" type="submit">Render</button>
          </form>

          <div class="workbench">
            <label class="editor-pane">
              <span>Source</span>
              <textarea id="diagram-source" spellcheck="false"></textarea>
            </label>
            <section class="preview-pane" aria-live="polite" aria-label="Preview">
              <div class="preview-heading">
                <span>Preview</span>
                <output id="render-status">ready</output>
              </div>
              <div id="preview-output" class="preview-output"></div>
            </section>
          </div>
        </div>
      </section>

      <section id="asciidoctor-preview" class="asciidoctor-preview-section page-panel" aria-labelledby="asciidoctor-preview-title">
        <div class="section-heading">
          <p class="eyebrow">Asciidoctor.js</p>
          <h2 id="asciidoctor-preview-title">{asciidoctorPreviewTitle}</h2>
          <p>{asciidoctorPreviewBody}</p>
        </div>

        <div class="document-preview" aria-label="Asciidoctor.js document preview">
          <label class="document-source-pane">
            <span>{asciidoctorSourceLabel}</span>
            <textarea id="asciidoc-source" spellcheck="false"></textarea>
          </label>
          <section class="document-output-pane" aria-live="polite" aria-label={asciidoctorPreviewLabel}>
            <div class="preview-heading">
              <span>{asciidoctorPreviewLabel}</span>
              <output id="asciidoc-status">ready</output>
            </div>
            <article id="asciidoc-preview-output" class="asciidoc-preview-output"></article>
          </section>
        </div>
      </section>

      <section class="details" aria-label="Project details">
        {details.map((item) => (
          <div>
            <h2>{item.title}</h2>
            <p set:html={item.body} />
          </div>
        ))}
      </section>
    </main>

    <script>
      import asciidoctorFactory from '@asciidoctor/core'
      import { renderToString } from '@plantuml/core'
      import bitfield from 'bit-field'
      import JSON5 from 'json5'
      import mermaid from 'mermaid'
      import nomnoml from 'nomnoml'
      import loadPikchr from 'pikchr-js'
      import { instance as createGraphviz } from '@viz-js/viz'
      import * as vega from 'vega'
      import * as vegaInterpreter from 'vega-interpreter'
      import * as vegaLite from 'vega-lite'
      import WaveDrom from 'wavedrom'
      import waveSkin from 'wavedrom/skins/default.js'
      import { hydrateEmbeddedDiagrams, installNetworkGuards } from '../../src/browser.js'
      import { registerBrowserDiagrams } from '../lib/browser-kroki.js'

      const samples = {
        plantuml: `@startuml
skinparam backgroundColor transparent
actor Writer
participant "AsciiDoc" as Doc
participant "Embedded target" as Target
participant "Local renderer" as Renderer

Writer -> Doc: diagram block
Doc -> Target: inert HTML
Target -> Renderer: hydrate in browser
Renderer --> Writer: SVG preview
@enduml`,
        mermaid: `flowchart LR
  A[AsciiDoc source] --> B{Kroki block?}
  B -->|yes| C[Embedded HTML target]
  C --> D[Local renderer]
  D --> E[SVG in host page]`,
        nomnoml: `[Source] -> [Embedded target]
[Embedded target] -> [Hydration]
[Hydration] -> [Local SVG]`,
        vegalite: `{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "description": "Renderer confidence by diagram type.",
  "data": {
    "values": [
      { "type": "Mermaid", "score": 7 },
      { "type": "PlantUML", "score": 8 },
      { "type": "Vega-Lite", "score": 6 },
      { "type": "WaveDrom", "score": 5 }
    ]
  },
  "mark": { "type": "bar", "cornerRadiusEnd": 3 },
  "encoding": {
    "x": { "field": "score", "type": "quantitative" },
    "y": { "field": "type", "type": "nominal", "sort": "-x" },
    "color": { "value": "#0f766e" }
  }
}`,
        vega: `{
  "$schema": "https://vega.github.io/schema/vega/v6.json",
  "width": 300,
  "height": 120,
  "padding": 8,
  "data": [
    {
      "name": "table",
      "values": [
        { "x": 0, "y": 28 },
        { "x": 1, "y": 55 },
        { "x": 2, "y": 43 },
        { "x": 3, "y": 81 }
      ]
    }
  ],
  "scales": [
    { "name": "x", "type": "point", "domain": { "data": "table", "field": "x" }, "range": "width" },
    { "name": "y", "type": "linear", "domain": { "data": "table", "field": "y" }, "range": "height", "nice": true }
  ],
  "marks": [
    {
      "type": "line",
      "from": { "data": "table" },
      "encode": {
        "enter": {
          "x": { "scale": "x", "field": "x" },
          "y": { "scale": "y", "field": "y" },
          "stroke": { "value": "#0f766e" },
          "strokeWidth": { "value": 3 }
        }
      }
    }
  ]
}`,
        wavedrom: `{ signal: [
  { name: "clk", wave: "p....." },
  { name: "req", wave: "01.0.." },
  { name: "ack", wave: "0.10.." },
  { name: "bus", wave: "x.345x", data: ["A", "B", "C"] }
]}`,
        bytefield: `{
          reg: [
            { bits: 7, name: "opcode" },
            { bits: 5, name: "rd" },
            { bits: 5, name: "rs1" },
            { bits: 3, name: "funct3" },
            { bits: 12, name: "imm" }
          ]
}`,
        svgbob: `       .--.
AsciiDoc -->|local| Kroki
       \`--'`,
        pikchr: `box "AsciiDoc" fit
arrow
box "Embedded target" fit
arrow
box "Local SVG" fit`,
        graphviz: `digraph {
  rankdir=LR
  node [shape=box, style="rounded,filled", fillcolor="#ecfeff"]
  AsciiDoc -> EmbeddedTarget -> LocalRenderer -> SVG
}`,
      }

      const documentSample = `= Local diagram preview
:toc:

This page converts the whole document with Asciidoctor.js and then hydrates Kroki-compatible diagram blocks locally.

[mermaid]
----
flowchart LR
  Source[AsciiDoc source] --> Asciidoctor[Asciidoctor.js]
  Asciidoctor --> Target[Embedded diagram target]
  Target --> Hydrator[Browser hydrator]
  Hydrator --> Preview[Rendered preview]
----

== Why it matters

* The AsciiDoc source stays on the page.
* The diagram block is rendered without a Kroki server.
* The preview uses the same extension boundary as host applications.`

      const diagramType = document.querySelector('#diagram-type')
      const source = document.querySelector('#diagram-source')
      const preview = document.querySelector('#preview-output')
      const status = document.querySelector('#render-status')
      const form = document.querySelector('.controls')
      const asciidocSource = document.querySelector('#asciidoc-source')
      const asciidocPreview = document.querySelector('#asciidoc-preview-output')
      const asciidocStatus = document.querySelector('#asciidoc-status')
      const asciidoctor = asciidoctorFactory()
      const graphviz = createGraphviz()
      const pikchr = loadPikchr()

      globalThis.WaveSkin = waveSkin
      installNetworkGuards(globalThis)
      mermaid.initialize({
        startOnLoad: false,
        securityLevel: 'strict',
        theme: 'default',
      })

      function renderPlantUml(sourceText) {
        return new Promise((resolve, reject) => {
          try {
            renderToString(
              sourceText.split(/\r\n|\r|\n/),
              (svg) => resolve(svg),
              (message) => reject(new Error(String(message || 'PlantUML rendering failed'))),
            )
          } catch (error) {
            reject(error)
          }
        })
      }

      function escapeSvgText(value) {
        return String(value)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
      }

      function renderTextDiagramSvg(sourceText) {
        const lines = sourceText.split(/\r\n|\r|\n/)
        const width = Math.max(180, Math.max(...lines.map((line) => line.length), 1) * 8 + 24)
        const height = Math.max(48, lines.length * 18 + 24)
        const text = lines
          .map((line, index) => `<text x="12" y="${24 + index * 18}">${escapeSvgText(line)}</text>`)
          .join('')
        return `<svg xmlns="http://www.w3.org/2000/svg" role="img" viewBox="0 0 ${width} ${height}" width="${width}" height="${height}"><rect width="100%" height="100%" rx="6" fill="#f8fafc" stroke="#94a3b8"/><g font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-size="14" fill="#14211f">${text}</g></svg>`
      }

      async function renderGraphviz(sourceText) {
        const viz = await graphviz
        return viz.renderString(sourceText, { format: 'svg' })
      }

      function createAsciiDoc(type, sourceText) {
        return `[${type}]
----
${sourceText}
----`
      }

      function createRegistry() {
        const registry = asciidoctor.Extensions.create()
        registerBrowserDiagrams(registry, {
          defaultFormat: 'svg',
          diagramNames: Object.keys(samples),
        })
        return registry
      }

      async function hydratePreview(container) {
        return hydrateEmbeddedDiagrams(container, {
          libraries: {
            mermaid,
            nomnoml,
            vega,
            vegaLite,
            vegaInterpreter,
            WaveDrom,
            JSON5,
            bitfield,
            svgbob: renderTextDiagramSvg,
            pikchr: await pikchr,
            graphviz: renderGraphviz,
          },
          renderers: {
            plantuml: async ({ source: sourceText, output }) => {
              output.innerHTML = await renderPlantUml(sourceText)
            },
          },
        })
      }

      async function renderPreview() {
        const type = diagramType.value
        status.value = 'rendering'
        preview.textContent = ''

        try {
          preview.innerHTML = String(asciidoctor.convert(createAsciiDoc(type, source.value), {
            safe: 'safe',
            backend: 'html5',
            standalone: false,
            extension_registry: createRegistry(),
            attributes: {
              'allow-uri-read': false,
            },
          }))

          const results = await hydratePreview(preview)
          const failed = results.find((result) => !result.ok)
          status.value = failed || results.length === 0 ? 'failed' : 'rendered'
        } catch (error) {
          preview.innerHTML = `<pre class="site-error"></pre>`
          preview.querySelector('.site-error').textContent =
            error instanceof Error ? error.message : String(error)
          status.value = 'failed'
        }
      }

      async function renderDocumentPreview() {
        asciidocStatus.value = 'rendering'
        asciidocPreview.textContent = ''

        try {
          asciidocPreview.innerHTML = String(asciidoctor.convert(asciidocSource.value, {
            safe: 'safe',
            backend: 'html5',
            standalone: false,
            extension_registry: createRegistry(),
            attributes: {
              'allow-uri-read': false,
            },
          }))

          const results = await hydratePreview(asciidocPreview)
          const failed = results.find((result) => !result.ok)
          asciidocStatus.value = failed || results.length === 0 ? 'failed' : 'rendered'
        } catch (error) {
          asciidocPreview.innerHTML = `<pre class="site-error"></pre>`
          asciidocPreview.querySelector('.site-error').textContent =
            error instanceof Error ? error.message : String(error)
          asciidocStatus.value = 'failed'
        }
      }

      diagramType.addEventListener('change', () => {
        source.value = samples[diagramType.value]
        renderPreview()
      })

      form.addEventListener('submit', (event) => {
        event.preventDefault()
        renderPreview()
      })

      asciidocSource.addEventListener('input', () => {
        renderDocumentPreview()
      })

      source.value = samples[diagramType.value]
      asciidocSource.value = documentSample
      renderPreview()
      renderDocumentPreview()
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --ink: #14211f;
    --muted: #5a6865;
    --paper: #f7f5ef;
    --surface: #ffffff;
    --line: #cfd8d4;
    --accent: #0f766e;
    --accent-strong: #115e59;
    --warm: #b45309;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-width: 320px;
    color: var(--ink);
    background:
      linear-gradient(180deg, rgba(15, 118, 110, 0.08), transparent 34rem),
      var(--paper);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    line-height: 1.55;
  }

  main {
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    padding: 28px 0 48px;
  }

  .language-nav {
    display: flex;
    justify-content: flex-end;
  }

  .page-nav {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
    padding: 10px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(247, 245, 239, 0.92);
    backdrop-filter: blur(12px);
  }

  .page-nav a {
    border-radius: 999px;
    padding: 8px 12px;
    color: var(--accent-strong);
    font-size: 0.86rem;
    font-weight: 800;
    text-decoration: none;
  }

  .page-nav a:hover,
  .page-nav a:focus-visible {
    background: rgba(15, 118, 110, 0.1);
  }

  .page-panel {
    scroll-margin-top: 78px;
  }

  .language-nav a {
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 7px 10px;
    color: var(--accent-strong);
    background: rgba(255, 255, 255, 0.82);
    font-size: 0.88rem;
    font-weight: 800;
    text-decoration: none;
  }

  .language-nav a:hover,
  .language-nav a:focus-visible {
    border-color: var(--accent);
    background: rgba(15, 118, 110, 0.08);
  }

  .hero {
    min-height: min(760px, calc(100svh - 32px));
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    gap: 24px;
    align-items: center;
    padding: clamp(28px, 6vw, 72px) 0 36px;
  }

  .hero-visual,
  .value-props > article,
  .playground,
  .document-preview,
  .details > div {
    min-width: 0;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.88);
    box-shadow: 0 18px 48px rgba(20, 33, 31, 0.08);
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
  }

  .eyebrow {
    margin: 0 0 16px;
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  p {
    overflow-wrap: anywhere;
  }

  h1 {
    margin: 0;
    max-width: 13ch;
    font-size: clamp(2.4rem, 6vw, 5.4rem);
    line-height: 0.96;
    letter-spacing: 0;
  }

  .lead {
    margin: 24px 0 0;
    color: var(--muted);
    font-size: clamp(1.02rem, 2vw, 1.22rem);
    max-width: 680px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    margin-top: 28px;
  }

  .hero-actions a,
  .hero-actions code {
    border: 1px solid rgba(15, 118, 110, 0.28);
    border-radius: 6px;
    padding: 10px 12px;
    text-decoration: none;
  }

  .hero-actions a {
    color: white;
    background: var(--accent);
    border-color: var(--accent);
    font-weight: 800;
  }

  .hero-actions a:hover,
  .hero-actions a:focus-visible {
    background: var(--accent-strong);
  }

  .hero-actions .secondary-action {
    color: var(--accent-strong);
    background: rgba(255, 255, 255, 0.82);
    border-color: rgba(15, 118, 110, 0.28);
    font-weight: 800;
  }

  .hero-actions code {
    color: var(--accent-strong);
    background: rgba(15, 118, 110, 0.08);
    font-size: 0.88rem;
    overflow-wrap: anywhere;
  }

  .hero-visual {
    display: grid;
    gap: 12px;
    padding: 16px;
    background: #fbfaf6;
  }

  .hero-visual > div {
    min-width: 0;
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 14px;
    background: white;
  }

  .hero-visual span {
    display: block;
    margin-bottom: 8px;
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .hero-visual pre,
  .hero-visual p {
    margin: 0;
  }

  .hero-visual pre {
    max-width: 100%;
    overflow: auto;
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    font-size: 0.78rem;
    line-height: 1.45;
    white-space: pre;
  }

  .hero-visual p {
    color: var(--muted);
    font-weight: 700;
  }

  .value-props {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    margin-bottom: 42px;
  }

  .value-props > article {
    padding: 20px;
  }

  .section-heading {
    max-width: 760px;
    margin-bottom: 16px;
  }

  .section-heading h2 {
    margin: 0;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
  }

  .section-heading p:not(.eyebrow) {
    margin: 12px 0 0;
    color: var(--muted);
    font-size: 1rem;
  }

  .playground {
    min-width: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .controls {
    min-height: 68px;
    display: flex;
    gap: 12px;
    align-items: end;
    padding: 16px;
    border-bottom: 1px solid var(--line);
    background: #fbfaf6;
  }

  label {
    min-width: 0;
  }

  label > span,
  .preview-heading span {
    display: block;
    margin-bottom: 6px;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .controls label {
    flex: 1;
  }

  select,
  button,
  textarea {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 6px;
    color: var(--ink);
    background: var(--surface);
    font: inherit;
  }

  select,
  button {
    min-height: 42px;
  }

  select {
    padding: 0 12px;
  }

  button {
    width: auto;
    min-width: 112px;
    padding: 0 18px;
    border-color: var(--accent);
    color: white;
    background: var(--accent);
    font-weight: 800;
    cursor: pointer;
  }

  button:hover,
  button:focus-visible {
    background: var(--accent-strong);
  }

  .workbench {
    flex: 1;
    min-height: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  }

  .editor-pane,
  .preview-pane {
    min-width: 0;
    min-height: 0;
    padding: 16px;
  }

  .editor-pane {
    display: flex;
    flex-direction: column;
    border-right: 1px solid var(--line);
  }

  textarea {
    flex: 1;
    min-height: 480px;
    resize: none;
