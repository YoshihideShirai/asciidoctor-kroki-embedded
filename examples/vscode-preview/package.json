{
  "name": "asciidoctor-kroki-embedded-vscode-preview",
  "displayName": "AsciiDoctor Kroki Embedded Preview",
  "description": "Local VS Code validation harness for asciidoctor-kroki-embedded rendering.",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/extension.cjs",
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onCommand:asciidoctor-kroki-embedded.preview",
    "onCommand:asciidoctor-kroki-embedded.refresh"
  ],
  "contributes": {
    "commands": [
      {
        "command": "asciidoctor-kroki-embedded.preview",
        "title": "Open Kroki Embedded Preview",
        "category": "AsciiDoc"
      },
      {
        "command": "asciidoctor-kroki-embedded.refresh",
        "title": "Refresh Kroki Embedded Preview",
        "category": "AsciiDoc"
      }
    ],
    "configuration": {
      "title": "AsciiDoctor Kroki Embedded Preview",
      "properties": {
        "asciidoctor-kroki-embedded.allowedPreviewHosts": {
          "type": "array",
          "default": [],
          "scope": "resource",
          "items": {
            "type": "string",
            "pattern": "^(https?://)?[^\\s*/?#]+$"
          },
          "markdownDescription": "Hosts that remote preview images may load from. Entries may be host names like `example.com`; an `http` or `https` scheme may be included to restrict the allowed scheme. Empty by default, so remote images are blocked."
        }
      }
    }
  },
  "scripts": {
    "build": "npm run clean && npm run bundle:extension && npm run bundle:webview",
    "bundle:extension": "esbuild src/extension.js --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.cjs",
    "bundle:webview": "esbuild src/webview.js --bundle --platform=browser --format=iife --global-name=KrokiEmbeddedPreview --alias:fs=./src/shims/empty.js --alias:node:fs=./src/shims/empty.js --alias:path=./src/shims/empty.js --alias:node:path=./src/shims/empty.js --outfile=dist/webview.js",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "generate:preview": "node scripts/generate-standalone-preview.mjs",
    "verify:no-network": "node scripts/verify-no-network.mjs",
    "smoke:preview": "node scripts/smoke-preview.mjs",
    "test": "node --test test/*.test.mjs",
    "verify": "npm run verify:no-network && npm test && npm run build && npm run generate:preview && npm run smoke:preview"
  },
  "dependencies": {
    "@asciidoctor/core": "^3.0.4",
    "@plantuml/core": "^1.2026.6",
    "@terrastruct/d2": "^0.1.33",
    "@viz-js/viz": "^3.28.0",
    "asciidoctor-kroki-embedded": "file:../..",
    "bit-field": "^1.9.0",
    "json5": "^2.2.3",
    "mermaid": "^11.15.0",
    "nomnoml": "^1.7.0",
    "pikchr-js": "^0.1.4",
    "vega": "^6.2.0",
    "vega-interpreter": "^2.2.1",
    "vega-lite": "^6.4.3",
    "wavedrom": "^3.6.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "esbuild": "^0.28.1"
  }
}
